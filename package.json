{
  "name": "daily-top-ten",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --max-warnings 0",
    "build": "pnpm --filter @daily/web build && pnpm --filter @daily/publisher build",
    "e2e": "playwright test",
    "seed:test": "NODE_ENV=test tsx tests/e2e/seed.ts",
    "dev": "pnpm --parallel --filter './apps/*' dev"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.54.1",
    "eslint": "^9.39.2",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
